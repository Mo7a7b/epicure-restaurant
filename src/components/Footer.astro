---
import Image from "astro/components/Image.astro";
---

<footer class="bg-[#1a1a1a] border-t border-[#333333]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <h3
          class="font-(family-name:--font-playfair) font-bold text-xl flex items-center gap-2 text-[#d4af37]! mb-4"
        >
          <Image
            src="/assets/logo.png"
            alt="Epicure's Logo"
            width={40}
            height={40}
          />
          Epicure
        </h3>
        <p class="text-muted-foreground text-sm leading-relaxed">
          Fine dining excellence crafted with passion and the finest
          ingredients.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="font-serif font-bold text-foreground mb-4">Navigation</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="/"
              class="text-muted-foreground hover:text-accent transition-colors"
              >Home</a
            >
          </li>
          <li>
            <a
              href="/menu"
              class="text-muted-foreground hover:text-accent transition-colors"
              >Menu</a
            >
          </li>
          <li>
            <a
              href="/about"
              class="text-muted-foreground hover:text-accent transition-colors"
              >About</a
            >
          </li>
        </ul>
      </div>

      <!-- Hours -->
      <div>
        <h4 class="font-serif font-bold text-foreground mb-4">Hours</h4>
        <ul class="space-y-2 text-sm text-muted-foreground">
          <li>Tue - Thu: 5:00 PM - 11:00 PM</li>
          <li>Fri - Sat: 5:00 PM - 12:00 AM</li>
          <li>Sun: 5:00 PM - 10:00 PM</li>
          <li>Monday: Closed</li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-serif font-bold text-foreground mb-4">Contact</h4>
        <ul class="space-y-2 text-sm text-muted-foreground">
          <li>
            <a
              href="tel:+1234567890"
              class="hover:text-accent transition-colors">(123) 456-7890</a
            >
          </li>
          <li>
            <a
              href="mailto:hello@epicure.com"
              class="hover:text-accent transition-colors">hello@epicure.com</a
            >
          </li>
          <li>123 Culinary Lane<br />Chef City, CC 12345</li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-border mb-8"></div>

    <!-- Bottom -->
    <div class="flex flex-col md:flex-row items-center justify-between">
      <p class="text-sm text-muted-foreground">
        &copy; {new Date().getFullYear()} Epicure. All rights reserved.
      </p>
      <div class="flex gap-6 mt-4 md:mt-0">
        <a
          href="#"
          class="text-muted-foreground hover:text-accent transition-colors text-sm"
        >
          Privacy Policy
        </a>
        <a
          href="#"
          class="text-muted-foreground hover:text-accent transition-colors text-sm"
        >
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    color: white;
  }
  h4 {
    font-family: var(--font-playfair);
  }
  p,
  a,
  li {
    color: #a0a0a0;
    transition: 0.3s ease;
  }
  a:hover {
    color: #d4af37;
  }
</style>
